<?xml version="1.0"?>
<robot name="wx250" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Argumentos -->
  <xacro:arg name="robot_name" default="wx250"/>
  <xacro:arg name="base_link_frame" default="base_link"/>
  <xacro:arg name="use_world_frame" default="false"/>
  <xacro:arg name="external_urdf_loc" default=""/>
  <xacro:arg name="use_gripper" default="true"/>

  <!-- Incluir el URDF original del WX250 -->
  <xacro:include filename="$(find interbotix_xsarm_descriptions)/urdf/wx250.urdf.xacro"/>

  <!-- Joint fijo world→base_link: ancla físicamente el robot al mundo en Gazebo Harmonic -->
  <link name="world"/>
  <joint name="world_fixed" type="fixed">
    <origin xyz="-0.165 0 0.4" rpy="0 0 0"/>
    <parent link="world"/>
    <child link="wx250/base_link"/>
  </joint>

  <!-- Añadir materiales/colores para visualización en Gazebo -->
  <gazebo reference="wx250/base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  
  <gazebo reference="wx250/shoulder_link">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="wx250/upper_arm_link">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="wx250/forearm_link">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="wx250/wrist_link">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="wx250/gripper_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo>
    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <joint_name>waist</joint_name>
      <joint_name>shoulder</joint_name>
      <joint_name>elbow</joint_name>
      <joint_name>wrist_angle</joint_name>
      <joint_name>wrist_rotate</joint_name>
      <joint_name>gripper</joint_name>
      <joint_name>left_finger</joint_name>
      <joint_name>right_finger</joint_name>
    </plugin>
  </gazebo>

  <!-- Sobrescribir ros2_control para usar gz_ros2_control en simulación -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="waist">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="shoulder">
      <command_interface name="position">
        <param name="min">-1.88</param>
        <param name="max">1.99</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="elbow">
      <command_interface name="position">
        <param name="min">-2.15</param>
        <param name="max">1.61</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_angle">
      <command_interface name="position">
        <param name="min">-1.75</param>
        <param name="max">2.15</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_rotate">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_finger">
      <command_interface name="position">
        <param name="min">0.015</param>
        <param name="max">0.037</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- Plugin de gz_ros2_control para Gazebo Harmonic -->
  <gazebo>
    <plugin
      filename="gz_ros2_control-system"
      name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find sim_gazebo)/config/wx250_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo>
    <static>false</static>
    <self_collide>false</self_collide>
  </gazebo>

</robot>